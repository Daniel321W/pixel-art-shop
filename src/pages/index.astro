---
import Layout from '../layouts/Layout.astro';
import { products } from '../data/products.js';
---

<Layout title="Pixel Art Shop - Unikalne ozdoby z koralików">
  
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
      <div class="text-2xl font-bold text-indigo-600">Pixel<span class="text-gray-800">Shop</span></div>
      <div class="space-x-4">
        <a href="#galeria" class="text-gray-600 hover:text-indigo-600 font-medium">Galeria</a>
        <a href="#zamow" class="bg-indigo-600 text-white px-4 py-2 rounded-full hover:bg-indigo-700 transition">Zamów projekt</a>
      </div>
    </div>
  </nav>

  <header class="bg-indigo-50 py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold text-gray-900 mb-6">
        Twoje ulubione postacie <br/> <span class="text-indigo-600">w wersji Pixel Art</span>
      </h1>
      <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
        Ręcznie robione ozdoby z koralików. Breloki, magnesy, podstawki i figurki. 
        Wybierz gotowy wzór lub zamów coś unikalnego!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#galeria" class="px-8 py-3 bg-indigo-600 text-white font-bold rounded-lg hover:bg-indigo-700 transition shadow-lg text-center">
          Zobacz Gotowe Wzory
        </a>
        
      </div>
    </div>
  </header>

  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-8 py-16 px-4">
    
    <aside class="w-full lg:w-80 bg-white border-4 border-indigo-600 p-6 flex-shrink-0 rounded-2xl shadow-xl h-fit lg:sticky lg:top-24">
      <h2 class="text-3xl font-black text-lime-400 italic mb-4 tracking-wide drop-shadow-md" style="text-shadow: 2px 2px 0px #312e81;">
        OKAZJA
      </h2>
      <p class="text-sm text-gray-700 mb-4 font-bold">
        Śpiesz się, oferta kończy się za:
      </p>

      <div class="flex gap-2 mb-8">
        <div class="flex flex-col items-center">
          <span id="days" class="text-2xl font-bold text-indigo-900 bg-indigo-50 px-3 py-2 rounded border border-indigo-200 w-14 text-center">--</span>
          <span class="text-xs text-indigo-600 mt-1">dni.</span>
        </div>
        <div class="flex flex-col items-center">
          <span id="hours" class="text-2xl font-bold text-indigo-900 bg-indigo-50 px-3 py-2 rounded border border-indigo-200 w-14 text-center">--</span>
          <span class="text-xs text-indigo-600 mt-1">godz.</span>
        </div>
        <div class="flex flex-col items-center">
          <span id="mins" class="text-2xl font-bold text-indigo-900 bg-indigo-50 px-3 py-2 rounded border border-indigo-200 w-14 text-center">--</span>
          <span class="text-xs text-indigo-600 mt-1">min.</span>
        </div>
        <div class="flex flex-col items-center">
          <span id="secs" class="text-2xl font-bold text-indigo-900 bg-indigo-50 px-3 py-2 rounded border border-indigo-200 w-14 text-center">--</span>
          <span class="text-xs text-indigo-600 mt-1">sek.</span>
        </div>
      </div>

      <div class="mt-4 pt-4 border-t border-gray-100">
        <div class="relative bg-gray-50 rounded-lg p-2 mb-4">
          <img id="deal-img" src="" alt="Hit tygodnia" class="w-full h-48 object-contain rounded-lg shadow-md" />
          <div class="absolute bottom-4 right-4 bg-indigo-900 rounded-full w-14 h-14 flex items-center justify-center shadow-lg border-2 border-white z-10">
            <span class="text-white text-[10px] font-bold text-center leading-tight uppercase">Bestseller</span>
          </div>
        </div>
        <h3 id="deal-title" class="text-lg font-bold text-indigo-900 line-clamp-1">Ładowanie...</h3>
        <div class="text-2xl font-black text-fuchsia-600 mt-2 mb-4">
          <span id="deal-price">-- PLN</span>
        </div>
        <a id="deal-link" href="#" target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-teal-500 hover:bg-teal-600 text-white font-bold py-3 rounded-xl transition transform hover:-translate-y-1 shadow-md cursor-pointer relative z-20">
          KUP TERAZ NA OLX
        </a>
      </div>
    </aside>

    <main id="galeria" class="flex-grow overflow-hidden relative">
      <div class="flex justify-between items-end mb-8">
        <h2 class="text-3xl font-bold text-gray-900 overflow-visible">Nowości w sklepie</h2>
        <div class="hidden md:flex gap-2 relative z-20">
          <button id="scrollLeft" class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-full hover:bg-gray-50 text-gray-600 transition shadow-sm cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button id="scrollRight" class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-full hover:bg-gray-50 text-gray-600 transition shadow-sm cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      <div id="carouselContainer" class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 pt-2" style="scrollbar-width: none; -ms-overflow-style: none;">
        
        {products.map((product) => (
          <div class="snap-start min-w-[280px] md:min-w-[300px] bg-white border border-gray-100 rounded-2xl overflow-visible shadow-sm hover:shadow-xl transition duration-300 flex flex-col relative group">
            
            <span class="absolute top-4 left-4 bg-indigo-600 text-white text-xs font-bold px-3 py-1 rounded-full z-10 shadow-sm pointer-events-none">NOWOŚĆ</span>
            
            <div class="aspect-square bg-gray-50 overflow-hidden relative p-4 flex items-center justify-center rounded-t-2xl">
              <img src={product.image} alt={product.title} class="max-h-full object-contain group-hover:scale-105 transition duration-500 drop-shadow-md" />
            </div>
            
            <div class="p-5 flex flex-col flex-grow border-t border-gray-50 bg-white rounded-b-2xl relative z-10">
              <div class="text-xs text-indigo-500 font-bold uppercase tracking-wide mb-1 tracking-wider">{product.category}</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2 line-clamp-2">{product.title}</h3>
              
              <div class="flex items-center gap-2 text-emerald-600 mb-4 font-medium text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v5c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
                Wysyłka OLX
              </div>

              <div class="text-2xl font-black text-indigo-900 mb-4">{product.price}</div>
              
              <a href={product.olxLink} target="_blank" rel="noopener noreferrer" class="mt-auto block w-full bg-teal-500 hover:bg-teal-600 text-white text-center py-3 rounded-xl font-bold transition cursor-pointer relative z-20">
                 KUP NA OLX
              </a>
            </div>
          </div>
        ))}
        
      </div>
    </main>
  </div>

  <section id="zamow" class="py-16 bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center mb-10">
      <h2 class="text-3xl font-bold mb-4">Masz własny pomysł?</h2>
      <p class="text-gray-400">Wyślij mi zdjęcie lub opisz co chcesz. Wycenię to dla Ciebie!</p>
    </div>

    <div class="max-w-xl mx-auto px-4 bg-gray-800 p-8 rounded-2xl shadow-2xl border border-gray-700">
      <form action="https://formspree.io/f/mjgeaegg" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Twój Email</label>
          <input type="email" name="email" required placeholder="adres@email.com" 
            class="w-full px-4 py-3 rounded-xl bg-gray-900 border border-gray-600 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Co chcesz zamówić?</label>
          <textarea name="message" rows="4" required placeholder="Np. Chcę Mario, ale w niebieskim stroju..." 
            class="w-full px-4 py-3 rounded-xl bg-gray-900 border border-gray-600 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition"></textarea>
        </div>
        <div>
           <label class="block text-sm font-medium text-gray-300 mb-1">Link do grafiki (opcjonalnie)</label>
           <input type="text" name="link" placeholder="Link do zdjęcia wzoru"
            class="w-full px-4 py-3 rounded-xl bg-gray-900 border border-gray-600 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition" />
        </div>
        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-xl transition transform hover:scale-[1.02] shadow-lg mt-2 cursor-pointer">
          Wyślij do darmowej wyceny
        </button>
      </form>
    </div>
  </section>

  <footer class="bg-gray-950 border-t border-gray-800 py-8 text-center text-gray-500 text-sm">
    <p>&copy; 2024 - 2026 PixelShop. Wszystkie prawa zastrzeżone.</p>
  </footer>

</Layout>

<style>
  #carouselContainer::-webkit-scrollbar {
    display: none;
  }
</style>

<script define:vars={{ products }}>
  // 1. Skrypt do przycisków karuzeli
  const container = document.getElementById('carouselContainer');
  const btnLeft = document.getElementById('scrollLeft');
  const btnRight = document.getElementById('scrollRight');

  if(btnLeft && btnRight && container) {
    btnLeft.addEventListener('click', () => {
      container.scrollBy({ left: -320, behavior: 'smooth' });
    });
    btnRight.addEventListener('click', () => {
      container.scrollBy({ left: 320, behavior: 'smooth' });
    });
  }

  // 2. Skrypt Prawdziwego Odliczania i Losowania (Wersja 3 - Twardy Reset Pamięci)
  const DEAL_DURATION = 2 * 24 * 60 * 60 * 1000; 

  function updateDealUI(product) {
    if(!product) return;
    document.getElementById('deal-img').src = product.image;
    document.getElementById('deal-title').innerText = product.title;
    document.getElementById('deal-price').innerText = product.price;
    document.getElementById('deal-link').href = product.olxLink; // <-- Tutaj zaciąga poprawny olxLink
  }

  function initializeDeal() {
    // UWAGA: Zmieniona nazwa klucza z 'v2' na 'v3', żeby przeglądarka zapomniała starą pamięć z Vinted!
    let expirationTime = localStorage.getItem('pixelShopDealExpires_v3');
    let savedProduct = localStorage.getItem('pixelShopDealProduct_v3');
    let now = new Date().getTime();

    // Reset i nowe losowanie
    if (!expirationTime || !savedProduct || now > parseInt(expirationTime)) {
      if (products && products.length > 0) {
        const randomProduct = products[Math.floor(Math.random() * products.length)];
        expirationTime = now + DEAL_DURATION;
        
        localStorage.setItem('pixelShopDealExpires_v3', expirationTime.toString());
        localStorage.setItem('pixelShopDealProduct_v3', JSON.stringify(randomProduct));
        
        updateDealUI(randomProduct);
      }
    } else {
      updateDealUI(JSON.parse(savedProduct));
    }
  }

  function tick() {
    let expirationTime = localStorage.getItem('pixelShopDealExpires_v3');
    if (!expirationTime) return;

    let now = new Date().getTime();
    let distance = parseInt(expirationTime) - now;

    if (distance < 0) {
      initializeDeal(); // Wylosuj nowy produkt i ustaw nowy czas
      distance = DEAL_DURATION;
    }

    let days = Math.floor(distance / (1000 * 60 * 60 * 24));
    let hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    let minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    let seconds = Math.floor((distance % (1000 * 60)) / 1000);

    document.getElementById('days').innerText = days.toString().padStart(2, '0');
    document.getElementById('hours').innerText = hours.toString().padStart(2, '0');
    document.getElementById('mins').innerText = minutes.toString().padStart(2, '0');
    document.getElementById('secs').innerText = seconds.toString().padStart(2, '0');
  }

  initializeDeal();
  tick(); 
  setInterval(tick, 1000); 
</script>